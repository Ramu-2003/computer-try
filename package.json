{
  "name": "computer-mode-battle",
  "version": "1.0.0",
  "description": "Humans vs AI Coding Battle Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "npm start --prefix client",
    "install-all": "npm install && cd client && npm install",
    "setup": "node setup.js",
    "test-setup": "node test-setup.js",
    "postinstall": "node setup.js"
  },
  "keywords": ["coding", "battle", "ai", "mern"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "socket.io": "^4.7.2",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1"
  }
}
